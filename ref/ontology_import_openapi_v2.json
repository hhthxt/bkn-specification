{
  "openapi": "3.0.3",
  "info": {
    "title": "业务知识网络导入服务",
    "description": "业务知识网络导入服务RESTful API集合,用于将JSON格式的业务模型自动导入到业务知识网络中。支持创建对象类和关系类。",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://ontology-manager-svc:13014",
      "description": "默认本地开发服务器"
    }
  ],
  "paths": {
    "/api/ontology-manager/in/v1/knowledge-networks": {
      "post": {
        "operationId": "createKnowledgeNetwork",
        "summary": "CreateKnowledgeNetwork",
        "description": "创建业务知识网络，为后续创建对象类和关系类做准备",
        "parameters": [
          {
            "name": "x-account-id",
            "required": true,
            "in": "header",
            "schema": {
              "type": "string"
            },
            "description": "账户ID"
          },
          {
            "name": "x-account-type",
            "required": true,
            "in": "header",
            "schema": {
              "type": "string"
            },
            "description": "账户类型"
          },
          {
            "name": "x-business-domain",
            "required": true,
            "in": "header",
            "schema": {
              "type": "string"
            },
            "description": "业务域ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "业务知识网络名称"
                  },
                  "branch": {
                    "type": "string",
                    "description": "分支ID",
                    "default": "main"
                  },
                  "base_branch": {
                    "type": "string",
                    "description": "来源分支，main分支为空字符串"
                  },
                  "comment": {
                    "type": "string",
                    "description": "备注"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "标签列表"
                  },
                  "icon": {
                    "type": "string",
                    "description": "图标"
                  },
                  "color": {
                    "type": "string",
                    "description": "颜色"
                  }
                },
                "required": ["name", "branch", "base_branch"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "资源ID"
                      }
                    },
                    "required": ["id"]
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "错误信息"
                    },
                    "code": {
                      "type": "string",
                      "description": "错误代码"
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          }
        }
      }
    },
    "/api/ontology-manager/in/v1/knowledge-networks/{knowledge_network_id}/object-types": {
      "post": {
        "operationId": "createObjectTypes",
        "summary": "CreateObjectTypes",
        "description": "在指定的业务知识网络中创建对象类",
