            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "created_count": {
                      "type": "integer",
                      "description": "创建成功的关系类数量"
                    },
                    "errors": {
                      "type": "array",
